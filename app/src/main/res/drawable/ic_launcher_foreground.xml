<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Central Connection Diamond Line (Symmetric Archetype) -->
    <path
        android:strokeWidth="1.8"
        android:strokeColor="#FBBF24"
        android:fillColor="#15FBBF24"
        android:pathData="M54,28 L80,54 L54,80 L28,54 Z" />
        
    <!-- Central Connection Squares Line (Balanced Layer) -->
    <path
        android:strokeWidth="1.0"
        android:strokeColor="#F59E0B"
        android:fillColor="#00000000"
        android:pathData="M38,38 L70,38 L70,70 L38,70 Z" />

    <!-- Central Neural Core Node -->
    <path
        android:pathData="M54,54m-12,0a12,12 0,1 1,24 0a12,12 0,1 1,-24 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="42"
                android:startY="42"
                android:endX="66"
                android:endY="66"
                android:type="linear">
                <item android:color="#FBBF24" android:offset="0.0"/>
                <item android:color="#F59E0B" android:offset="1.0"/>
            </gradient>
        </aapt:attr>
    </path>
    
    <!-- Inner Core Dot -->
    <path
        android:fillColor="#080808"
        android:pathData="M54,54m-4,0a4,4 0,1 1,8 0a4,4 0,1 1,-8 0" />

    <!-- 4 Cardinal Star Nodes (Curiosity, Decision, Learning, Focus) -->
    <!-- Top Star Node -->
    <path
        android:fillColor="#FBBF24"
        android:pathData="M54,20m-3.5,0a3.5,3.5 0,1 1,7 0a3.5,3.5 0,1 1,-7 0" />
    <!-- Right Star Node -->
    <path
        android:fillColor="#FBBF24"
        android:pathData="M88,54m-3.5,0a3.5,3.5 0,1 1,7 0a3.5,3.5 0,1 1,-7 0" />
    <!-- Bottom Star Node -->
    <path
        android:fillColor="#FBBF24"
        android:pathData="M54,88m-3.5,0a3.5,3.5 0,1 1,7 0a3.5,3.5 0,1 1,-7 0" />
    <!-- Left Star Node -->
    <path
        android:fillColor="#FBBF24"
        android:pathData="M20,54m-3.5,0a3.5,3.5 0,1 1,7 0a3.5,3.5 0,1 1,-7 0" />

</vector>
